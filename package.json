    "android:aab:release": "cd android && ./gradlew bundleRelease",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "generate:db": "tsx --tsconfig tsconfig.json scripts/generate-bundled-db.ts",
    "optimize:images": "node scripts/optimize-images.mjs",
    "test": "jest",
    "test:ci": "npm run typecheck && npm run test",
    "doctor": "npx expo-doctor"
  },
