{
  "expo": {
    "name": "Namma Madras",
    "slug": "namma-madras",
    "version": "1.0.4",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "namma-madras",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "description": "வந்தாரை வாழவைக்கும் சென்னை",
    "splash": {
      "backgroundColor": "#FAF8F5"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nammamadras.app"
    },
    "android": {
      "package": "com.nammamadras.app",
      "versionCode": 5,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#E5EEEA"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "extra": {
      "router": {}
    },
    "experiments": {
      "typedRoutes": true
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "buildArchs": ["arm64-v8a"],
            "enableBundleCompression": true,
            "enableMinifyInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true,
            "enablePngCrunchInReleaseBuilds": false,
            "useLegacyPackaging": true,
            "networkInspector": false
          }
        }
      ],
      "expo-router",
      "expo-sqlite",
      "expo-localization",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Namma Madras to use your location to sort nearby places by distance.",
          "locationWhenInUsePermission": "Allow Namma Madras to use your location to sort nearby places by distance."
        }
      ],
      [
        "expo-notifications",
        {
          "sounds": []
        }
      ],
      "./plugins/withAndroidDebugBundle.js"
    ]
  }
}
